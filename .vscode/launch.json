{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Python Debugger: Module",
			"type": "debugpy",
			"request": "launch",
			"cwd": "${workspaceFolder}/botc_tokens/generator/src",
			"module": "botc_tokens.__main__",
			"console": "integratedTerminal",
			"justMyCode": true,
			//"args": "${command:pickArgs}"
			"args": [
				"create",
				"--output-dir",
				"${workspaceFolder}/botc_tokens/tokens",
				"--components",
				"${workspaceFolder}/botc_tokens/components",
				"${workspaceFolder}/botc_tokens/inputs"
			]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Debug Launch Dump from Bloodstar",
			"cwd": "${workspaceFolder}/botc_tokens",
			"skipFiles": [
				"<node_internals>/**"
			],
			"program": "dump_from_bloodstar.js",
			"args": [
				/** /
				"images",
				"./inputs/homebrew",
				"./inputs/trust-me-bro",
				"./inputs/imppreposterous",
				//*/
				/**/
				"json",
				"./homebrew_characters_list.json",
				"./trustmebro_characters_list.json",
				"./imppreposterous_characters_list.json",
				//*/
			]
		}
	]
}